# UPIPays — upays.in production environment
# Copy to payment-hub/.env on VPS: /www/wwwroot/upays.in/payment-hub/.env

APP_ENV=production
APP_PORT=8091
APP_URL=https://upays.in

# MySQL — create database "upipays" first (see LOCAL-SETUP.md)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=upipays
DB_USER=upipays
DB_PASSWORD=CHANGE_ME

REDIS_URL=redis://127.0.0.1:6379

PAYMENT_PROVIDER=upi_email

UPI_ID=yourname@ybl
UPI_PAYEE_NAME=UPIPays

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.bank.alerts@gmail.com
IMAP_PASSWORD=your_gmail_app_password
IMAP_SENDER_FILTER=hdfcbank
EMAIL_POLL_INTERVAL_SEC=30
ORDER_EXPIRY_MINUTES=5
PROFILE_BOOTSTRAP=false

JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARS
LOG_LEVEL=info
