# Server
APP_ENV=development
APP_PORT=8091
APP_URL=http://localhost:8091

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=upipays
DB_USER=upipays_user
DB_PASSWORD=your_password_here

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Payment provider: upi_email (default) or phonepe
PAYMENT_PROVIDER=upi_email

# UPI (when PAYMENT_PROVIDER=upi_email)
UPI_ID=yourname@ybl
UPI_PAYEE_NAME=UPIPays

# Bank email auto-verify (HDFC credit alerts via Gmail IMAP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.bank.alerts@gmail.com
IMAP_PASSWORD=your_app_password_here
IMAP_SENDER_FILTER=hdfcbank
EMAIL_POLL_INTERVAL_SEC=30
ORDER_EXPIRY_MINUTES=5
PROFILE_BOOTSTRAP=true

# PhonePe (when PAYMENT_PROVIDER=phonepe)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=PRODUCTION

# Security
JWT_SECRET=change_me_in_production_min_32_chars

LOG_LEVEL=info
